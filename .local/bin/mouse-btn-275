#!/bin/bash
# ~/.local/bin/mouse-btn-275

CLASS=$(hyprctl activewindow -j | jq -r '.class')
ADDRESS=$(hyprctl activewindow -j | jq -r '.address')

hyprctl dispatch focuswindow address:$ADDRESS
sleep 0.1

case "$CLASS" in
    "chrome-outlook.office.com__-Profile_1")
        wtype -M ctrl -M shift -k 1 -m ctrl -m shift
        ;;
    *)
        wtype -M alt -k Left -m alt
        ;;
esac
