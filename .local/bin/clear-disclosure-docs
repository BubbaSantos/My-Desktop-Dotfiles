#!/bin/bash

# Delete "Our Promise To You - CARA - [name].pdf" files (not Blank), older than 1 day
DISCLOSURE_DIR="$HOME/Documents/Work Documents/Disclosure Documents"

find "$DISCLOSURE_DIR" -maxdepth 1 -type f \
  -iname "Our Promise To You - CARA - *.pdf" \
  ! -iname "Our Promise To You - CARA - Blank.pdf" \
  -mtime +1 \
  -print -delete
