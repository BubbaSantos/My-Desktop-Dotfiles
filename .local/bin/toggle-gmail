#!/bin/bash

CLASS="vivaldi-mail.google.com__mail_u_0_-Profile_1"
SPECIAL="gmail"

WINDOW=$(hyprctl clients -j | python3 -c "
import json, sys
clients = json.load(sys.stdin)
for c in clients:
    if c['class'] == '$CLASS':
        print(c['workspace']['name'])
        break
")

if [[ "$WINDOW" == "special:$SPECIAL" ]]; then
    hyprctl dispatch togglespecialworkspace $SPECIAL
elif [[ -n "$WINDOW" ]]; then
    hyprctl dispatch movetoworkspacesilent special:$SPECIAL,class:^${CLASS}$
    hyprctl dispatch togglespecialworkspace $SPECIAL
else
    chromium --app=https://mail.google.com/mail/u/0/ --profile-directory="Default" &
fi
