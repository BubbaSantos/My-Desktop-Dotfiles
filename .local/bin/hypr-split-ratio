#!/bin/bash
config="$HOME/.config/hypr/looknfeel.conf"
MFACT_FILE="$HOME/.cache/hypr-mfact"
DSR_FILE="$HOME/.cache/hypr-dsr"

# Detect current layout from the general {} block
current_layout=$(sed -n '/^general {/,/^}/ s/^[[:space:]]*layout[[:space:]]*=[[:space:]]*//p' "$config")

# Read the currently active ratio depending on layout
if [[ "$current_layout" == "dwindle" ]]; then
    current_ratio=$(sed -n '/^dwindle {/,/^}/ s/^[[:space:]]*default_split_ratio[[:space:]]*=[[:space:]]*//p' "$config")
else
    current_ratio=$(sed -n '/^master {/,/^}/ s/^[[:space:]]*mfact[[:space:]]*=[[:space:]]*//p' "$config")
fi

# Build layout entries with a tick next to the active one
master_label="master"
dwindle_label="dwindle"
[[ "$current_layout" == "master" ]]  && master_label="master ✓"
[[ "$current_layout" == "dwindle" ]] && dwindle_label="dwindle ✓"

# Percentage -> value mapping. master uses 0.xx mfact, dwindle uses default_split_ratio.
percentages=(50 55 60 65 70 75 80 85)

# Map a percentage to the value for the current layout
pct_to_value() {
    local pct="$1"
    if [[ "$current_layout" == "dwindle" ]]; then
        # 50% -> 1.0 even split; each 5% step ~= 0.1 ratio change
        # 50->1.00, 55->1.10, 60->1.20, 65->1.30, 70->1.40, 75->1.50, 80->1.60, 85->1.70
        local steps=$(( (pct - 50) / 5 ))
        printf '1.%02d' "$(( steps * 10 ))"
    else
        printf '0.%02d' "$pct"
    fi
}

# Build the percentage menu, ticking whichever matches the current ratio
options=( "$master_label" "$dwindle_label" "─────────────" )
for pct in "${percentages[@]}"; do
    value=$(pct_to_value "$pct")
    label="${pct}%"
    [[ "$current_ratio" == "$value" ]] && label="${pct}% ✓"
    options+=( "$label" )
done

choice=$(printf '%s\n' "${options[@]}" | fzf \
    --prompt="Master Size > " \
    --height=15 \
    --border=rounded \
    --no-info \
    --no-sort)

[[ -z "$choice" ]] && exit 0

set_layout() {
    local value="$1"
    sed -i '/^general {/,/^}/ s/^\([[:space:]]*\)layout[[:space:]]*=.*/\1layout = '"$value"'/' "$config"
    notify-send "Hyprland Layout" "Switched to $value" -u low
    hyprctl reload
}

set_ratio() {
    local pct="$1"
    local value
    value=$(pct_to_value "$pct")
    if [[ "$current_layout" == "dwindle" ]]; then
        sed -i '/^dwindle {/,/^}/ s/^\([[:space:]]*\)#\?default_split_ratio[[:space:]]*=.*/\1default_split_ratio = '"$value"'/' "$config"
        echo "$value" > "$DSR_FILE"
        notify-send "Dwindle Layout" "Split ratio ${pct}% ($value)" -u low
    else
        sed -i '/^master {/,/^}/ s/^\([[:space:]]*\)#\?mfact\(_[[:alnum:]_]*\)\?[[:space:]]*=.*/\1mfact = '"$value"'/' "$config"
        echo "$value" > "$MFACT_FILE"
        notify-send "Master Layout" "Master area ${pct}% ($value)" -u low
    fi
    hyprctl reload
}

# Strip any trailing tick before matching
case "${choice% ✓}" in
    "master")
        set_layout "master"
        ;;
    "dwindle")
        set_layout "dwindle"
        ;;
    "─────────────")
        exit 0
        ;;
    *)
        pct="${choice%\%}"
        set_ratio "$pct"
        ;;
esac
