#!/bin/bash
config="$HOME/.config/hypr/looknfeel.conf"
RATIO_FILE="$HOME/.cache/hypr-split-ratio"

options=(
    "65/35 (1.45)"
    "70/30 (1.55)"
    "80/20 (1.60)"
    "50/50 (default)"
)

choice=$(printf '%s\n' "${options[@]}" | fzf \
    --prompt="Split Ratio > " \
    --height=8 \
    --border=rounded \
    --no-info \
    --no-sort)

[[ -z "$choice" ]] && exit 0

set_ratio() {
    local value="$1"
    sed -i '/[[:space:]]*#\?default_split_ratio/d' "$config"
    sed -i '/[[:space:]]*#\?force_split/d' "$config"

    if [[ "$value" == "1.0" ]]; then
        echo "1.0" > "$RATIO_FILE"
        notify-send "Dwindle Layout" "Split ratio 50/50" -u low
    else
        sed -i "/^dwindle {/a\\    force_split = 2\n    default_split_ratio = $value" "$config"
        echo "$value" > "$RATIO_FILE"
        notify-send "Dwindle Layout" "Split ratio $choice" -u low
    fi
    hyprctl reload
}

case "$choice" in
    "65/35 (1.45)")   set_ratio "1.45" ;;
    "70/30 (1.55)")   set_ratio "1.55" ;;
    "80/20 (1.60)")   set_ratio "1.60" ;;
    "50/50 (default)") set_ratio "1.0" ;;
esac

