#!/usr/bin/env bash

STATE_FILE="$HOME/.local/state/waybar-layout"
current=$(cat "$STATE_FILE" 2>/dev/null || echo "full")

if [[ "$current" == "full" ]]; then
  echo '{"text": "󰀘", "tooltip": "Compact layout", "class": "layout-full"}'
else
  echo '{"text": "󰡵", "tooltip": "Full layout", "class": "layout-compact"}'
fi
