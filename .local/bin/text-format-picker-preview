#!/usr/bin/env bash
INPUT="$1"
MODE="$2"

case "$MODE" in
  "Title Case")    echo "$INPUT" | python3 -c "import sys; print(sys.stdin.read().title().rstrip())" ;;
  "UPPER CASE")    echo "${INPUT^^}" ;;
  "lower case")    echo "${INPUT,,}" ;;
  "Sentence case") python3 -c "
import sys
text = sys.stdin.read().rstrip()
print('. '.join(s.strip().capitalize() for s in text.split('. ')))
" <<< "$INPUT" ;;
  "camelCase")     echo "$INPUT" | python3 -c "
import sys, re
words = re.split(r'[\s_\-]+', sys.stdin.read().strip())
print(words[0].lower() + ''.join(w.capitalize() for w in words[1:]))
" ;;
  "PascalCase")    echo "$INPUT" | python3 -c "
import sys, re
words = re.split(r'[\s_\-]+', sys.stdin.read().strip())
print(''.join(w.capitalize() for w in words))
" ;;
  "snake_case")    echo "$INPUT" | python3 -c "
import sys, re
text = sys.stdin.read().strip()
text = re.sub(r'[\s\-]+', '_', text)
text = re.sub(r'([A-Z])', r'_\1', text).lstrip('_')
print(text.lower())
" ;;
  "kebab-case")    echo "$INPUT" | python3 -c "
import sys, re
text = sys.stdin.read().strip()
text = re.sub(r'[\s_]+', '-', text)
text = re.sub(r'([A-Z])', r'-\1', text).lstrip('-')
print(text.lower())
" ;;
  "SCREAMING_SNAKE_CASE") echo "$INPUT" | python3 -c "
import sys, re
text = sys.stdin.read().strip()
text = re.sub(r'[\s\-]+', '_', text)
text = re.sub(r'([A-Z])', r'_\1', text).lstrip('_')
print(text.upper())
" ;;
  "Trim Whitespace") echo "$INPUT" | python3 -c "import sys; print(' '.join(sys.stdin.read().split()))" ;;
  "Reverse Words")   echo "$INPUT" | python3 -c "import sys; words = sys.stdin.read().split(); print(' '.join(reversed(words)))" ;;
  "Toggle Case")     echo "$INPUT" | python3 -c "import sys; print(sys.stdin.read().rstrip().swapcase())" ;;
  "Slug (URL safe)") echo "$INPUT" | python3 -c "
import sys, re, unicodedata
text = sys.stdin.read().strip().lower()
text = unicodedata.normalize('NFKD', text).encode('ascii', 'ignore').decode()
text = re.sub(r'[^\w\s-]', '', text)
text = re.sub(r'[\s_]+', '-', text).strip('-')
print(text)
" ;;
esac
